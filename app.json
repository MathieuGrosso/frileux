{
  "expo": {
    "name": "Frileuse",
    "slug": "frileuse",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "frileuse",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.frileuse.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Frileuse a besoin de la caméra pour photographier ta tenue du jour.",
        "NSPhotoLibraryUsageDescription": "Frileuse a besoin d'accéder à tes photos pour choisir une photo de tenue.",
        "NSLocationWhenInUseUsageDescription": "Frileuse utilise ta position pour te donner la météo locale.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.frileuse.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Frileuse utilise ta position pour la météo locale."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Frileuse accède à tes photos pour les tenues."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a1a2e"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e287f75-b84d-42c3-932b-d23cb8917006"
      }
    },
    "owner": "batmat9",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e287f75-b84d-42c3-932b-d23cb8917006"
    }
  }
}
